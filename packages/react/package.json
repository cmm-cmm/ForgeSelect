{
  "name": "forge-select-react",
  "version": "0.4.0",
  "description": "React wrapper component for Forge Select.",
  "license": "MIT",
  "author": "KonexForge",
  "homepage": "https://forgeselect.konexforge.com/",
  "bugs": {
    "url": "https://github.com/cmm-cmm/ForgeSelect/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/ForgeSelect.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "forge-select": "^0.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
