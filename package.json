{
  "name": "forge-select",
  "version": "0.6.0",
  "description": "A modern, lightweight, highly customizable replacement for Select2.",
  "keywords": [
    "select",
    "dropdown",
    "combobox",
    "select2",
    "autocomplete",
    "multiselect",
    "tags"
  ],
  "license": "MIT",
  "author": "KonexForge",
  "homepage": "https://forgeselect.konexforge.com/",
  "bugs": {
    "url": "https://github.com/cmm-cmm/ForgeSelect/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/ForgeSelect.git"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/forge-select.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "sideEffects": false,
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "build": "tsup",
    "bench": "npm run build && node scripts/benchmark.mjs",
    "build:site": "npm run build && node scripts/build-site.mjs",
    "check:package": "npm run build && npm run build --workspaces --if-present && npm pack --dry-run --ignore-scripts && npm pack ./packages/react --dry-run --ignore-scripts && npm pack ./packages/vue --dry-run --ignore-scripts",
    "check:site": "npm run build:site && node scripts/check-site.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,jsonc,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,jsonc,md,css,yml,yaml}\"",
    "lint": "eslint .",
    "test": "vitest run",
    "test:browser": "npm run build && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run build",
    "prepublishOnly": "npm run verify",
    "deploy:cloudflare": "wrangler deploy"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "markdown-it": "^14.3.0",
    "prettier": "^3.9.5",
    "sharp": "^0.34.5",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
