{
  "name": "forge-select",
  "version": "0.2.0",
  "description": "A modern, lightweight, highly customizable replacement for Select2.",
  "keywords": [
    "select",
    "dropdown",
    "combobox",
    "select2",
    "autocomplete",
    "multiselect",
    "tags"
  ],
  "license": "MIT",
  "author": "KonexForge",
  "homepage": "https://forgeselect.konexforge.com/",
  "bugs": {
    "url": "https://github.com/cmm-cmm/ForgeSelect/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/ForgeSelect.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/forge-select.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:site": "npm run build && node scripts/build-site.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "deploy:cloudflare": "wrangler deploy"
  },
  "devDependencies": {
    "highlight.js": "^11.11.1",
    "jsdom": "^26.0.0",
    "markdown-it": "^14.3.0",
    "sharp": "^0.34.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.110.0"
  }
}
